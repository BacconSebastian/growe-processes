# URL base del backend de Growe (sin barra final). Obligatorio.
# Ejemplo producción: https://growe-api.up.railway.app
API_BASE_URL=http://localhost:3001

# Secret compartido entre este scheduler y el backend.
# Debe coincidir con la variable INTERNAL_JOBS_SECRET del backend. Obligatorio.
INTERNAL_JOBS_SECRET=cambia_este_secret_en_produccion

# Timeout en milisegundos para cada petición HTTP al backend. Opcional (default: 120000).
REQUEST_TIMEOUT_MS=120000

# Número máximo de reintentos ante errores de red/timeout. Opcional (default: 2).
# Solo aplica a fallos de red — los errores HTTP (4xx/5xx) nunca se reintentan.
MAX_RETRIES=2

# Milisegundos de espera entre reintentos. Opcional (default: 5000).
RETRY_DELAY_MS=5000
